export const styles = new Proxy({}, {
  get(_, field) {
    return new Proxy({}, {
      get(_, name) {
        return {[\`STYLE_\${field}\`]: {type: 'JSXSpreadAttribute', argument: \`styles.\${field}.\${name}\`}}
      }
    })
  }
})

export const variables = new Proxy({}, {
  get(_, collection) {
    return new Proxy({}, {
      get(_, name) {
        return {type: 'JSXExpressionContainer', expression: \`variables.\${collection}.\${name}\`}
      }
    })
  }
})

