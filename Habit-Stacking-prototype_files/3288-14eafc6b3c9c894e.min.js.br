let nextRef = 1
export function packExpressions(children: object) {
  if (children === null || children === undefined) {
    return children
  }
  if (Array.isArray(children)) {
    return children.map(packExpressions)
  }
  if (typeof children === 'object' && children.type === 'JSXExpressionContainer') {
    return <div data-expression={children.expression} />
  }
  return children
}
export function packRefs(value: any) {
  if (React.isValidElement(value)) {
    const ref = \`ref\${nextRef}\`
    nextRef += 1
    return [{ type: 'JSXRef', ref }, [<div key={ref} data-ref={ref}>{value}</div>]]
  } else if (Array.isArray(value)) {
    const newValue = []
    const refs = []
    for (const v of value) {
      const [childValue, childRefs] = packRefs(v)
      newValue.push(childValue)
      refs.push(...childRefs)
    }
    return [newValue, refs]
  } else if (typeof value === 'object' && !!value) {
    const newValue = {}
    const refs = []
    for (const [k, v] of Object.entries(value)) {
      if (k.startsWith('STYLE_') && typeof v === 'object' && v?.type === 'JSXSpreadAttribute') {
        // {...styles.text.body1} inside an override object evaluates to
        // {STYLE_text: {type:'JSXSpreadAttribute', argument:'styles.text.body1'}}.
        // Use SpreadExpression so formatJSX renders {...styles.text.body1} inline,
        // preserving insertion order alongside any sibling regular props.
        newValue[\`...\${v.argument}\`] = { type: 'SpreadExpression', value: v.argument }
      } else {
        const [childValue, childRefs] = packRefs(v)
        newValue[k] = childValue
        refs.push(...childRefs)
      }
    }
    return [newValue, refs]
  } else {
    return [value, []]
  }
}
export function packScenenode(name: string, rawProps: object) {
  const spreads = []
  const props = {}
  const refs = []
  for (const [k, v] of Object.entries(rawProps)) {
    if (k === 'children') {
      continue
    } else if (k.startsWith('STYLE_') && typeof v === 'object' && !!v && v.type === 'JSXSpreadAttribute') {
      // Keep spreads inline in props as SpreadExpression to preserve their
      // position relative to regular props. The formatter's stringifyProp
      // already renders SpreadExpression values as {...expr}.
      props[\`...\${v.argument}\`] = { type: 'SpreadExpression', value: v.argument }
    } else {
      const [prop, propRefs] = packRefs(v)
      props[k] = prop
      refs.push(...propRefs)
    }
  }
  const children = packExpressions(rawProps.children)
  return <div
    data-scenenode=""
    data-type={name}
    data-props={JSON.stringify(props)}
    data-spreads={JSON.stringify(spreads)}
  >
    {children}
    {refs}
  </div>
}
